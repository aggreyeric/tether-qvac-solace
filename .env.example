# =============================================================================
#  Solace — environment variables (Tether QVAC Hackathon)
# -----------------------------------------------------------------------------
#  Solace is LOCAL-FIRST: by design it needs NO cloud API keys. This file only
#  documents the optional knobs. Copy to `.env` if you want to change defaults,
#  but nothing here is a secret and nothing is required for the demo.
# =============================================================================

# Which engine the app should prefer when run with --real.
#   mock  → offline deterministic engine (default; instant, no downloads)
#   real  → genuine on-device QVAC engine (needs models downloaded)
SOLACE_MODE=mock

# Local QVAC server endpoint for the Python SDK (only used when QVAC_BACKEND
# is openai/auto and the real engine is running). Default local port is 5273.
QVAC_BASE_URL=http://127.0.0.1:5273/v1

# QVAC's local server needs no real key; this placeholder only exists because
# the OpenAI client requires a non-empty string.
QVAC_API_KEY=qvac-local-no-key-required

# Python SDK backend selection: auto | openai | stub
QVAC_BACKEND=stub

# Local model ids (Python SDK).
QVAC_MODEL=llama-3.2-1b-instruct
QVAC_EMBED_MODEL=qvac-embeddings
QVAC_NMT_MODEL=qvac-nmt
QVAC_OCR_MODEL=qvac-ocr

# Dashboard server port (TS app).
PORT=5274
